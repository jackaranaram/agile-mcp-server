{
  "name": "@jackaranaram/agile-mcp-server",
  "version": "1.0.2",
  "packageManager": "pnpm@9.15.0",
  "description": "Agile Project Management MCP server — plan epics, stories and tasks, then sync to GitHub (Jira, Azure DevOps coming soon)",
  "main": "dist/index.js",
  "bin": {
    "agile-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "mcpName": "io.github.jackaranaram/agile-mcp-server",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "prepublishOnly": "npm run build",
    "prepare": "husky install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jackaranaram/agile-mcp-server.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agile",
    "project-management",
    "github",
    "ai-agents",
    "claude",
    "cursor"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "axios": "^1.6.0",
    "axios-retry": "^4.5.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.4",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^8.56.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "semantic-release": "^25.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  }
}
